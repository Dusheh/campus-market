<!-- 买块 - 需求 -->
<view class="container">
  <!-- 顶部搜索 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索需求…" bindinput="onSearch" value="{{keyword}}"/>
  </view>

  <!-- 列表 -->
  <view class="list">
    <block wx:for="{{demands}}" wx:key="id">
      <navigator url="/pages/demand-detail/demand-detail?id={{item.id}}" class="card">
        <view class="card-header flex-between">
          <view class="flex-row">
            <text class="tag {{item.type === 'service' ? 'tag-service' : 'tag-goods'}}">{{item.type === 'service' ? '求服务' : '求购物品'}}</text>
            <text class="tag tag-demand" wx:if="{{item.isUrgent}}">急</text>
          </view>
          <text class="price" wx:if="{{item.budget}}">¥{{item.budget}}</text>
        </view>
        <text class="card-title text-ellipsis">{{item.title}}</text>
        <text class="card-desc text-ellipsis-2">{{item.description}}</text>
        <view class="card-footer flex-between">
          <view class="flex-row">
            <image class="avatar-sm" src="{{item.user.avatar}}"></image>
            <text>{{item.user.name}}</text>
          </view>
          <text class="time">{{item.createTime}}</text>
        </view>
      </navigator>
    </block>
    <view wx:if="{{demands.length === 0}}" class="empty">暂无需求</view>
  </view>

  <!-- 发布按钮 -->
  <view class="float-btn" bindtap="goPublish">
    <text class="float-icon">+</text>
  </view>
</view>