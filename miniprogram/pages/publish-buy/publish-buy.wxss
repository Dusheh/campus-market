.form-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.input {
  font-size: 28rpx;
  padding: 0;
}

.textarea {
  font-size: 28rpx;
  width: 100%;
  min-height: 200rpx;
  padding: 0;
}

.type-switch {
  gap: 20rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.type-btn.active {
  background: #FF9800;
  color: #ffffff;
}

.submit-btn {
  margin-top: 40rpx;
}