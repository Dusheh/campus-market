/* 首页 */
.banner {
  width: 100%;
  height: 360rpx;
}

.banner image {
  width: 100%;
  height: 100%;
}

/* 快速公呈 */
.quick-entry {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 32rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 30rpx;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.entry-sell {
  background-color: skyblue;
  /* TODO: 提信创序 */
}

.entry-buy {
  background-color: salmon;
  /* TODO: 提価创序 */
}

/* 内容列表 */
.section {
  margin-top: 32rpx;
}

.section-header {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

/* 水平欠动 */
.horizontal-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.horizontal-item {
  display: inline-block;
  width: 280rpx;
  margin-right: 24rpx;
}

.horizontal-img {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
}

.horizontal-title {
  font-size: 26rpx;
  margin-top: 12rpx;
}

/* 需求卡牄 */
.demand-card {
  padding: 24rpx 24rpx 24rpx 0;
  border-bottom: 2rpx solid #eeeeee;
}

.demand-title {
  font-size: 28rpx;
  margin-top: 16rpx;
}

.demand-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}