<!-- 卖板块 - 服务与物品列表 -->
<view class="container">
  <!-- 顶部搜索 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索服务或物品..." bindinput="onSearch" value="{{keyword}}"/>
  </view>

  <!-- 分类 Tab -->
  <scroll-view class="category-tabs" scroll-x>
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'service' ? 'active' : ''}}" bindtap="switchTab" data-tab="service">服务</view>
    <view class="tab-item {{currentTab === 'goods' ? 'active' : ''}}" bindtap="switchTab" data-tab="goods">二手物品</view>
  </scroll-view>

  <!-- 列表 -->
  <view class="list">
    <block wx:for="{{items}}" wx:key="id">
      <navigator url="/pages/{{item.type === 'service' ? 'service-detail' : 'goods-detail'}}/{{item.type === 'service' ? 'service-detail' : 'goods-detail'}}?id={{item.id}}" class="card">
        <view class="card-header flex-between">
          <view class="flex-row">
            <text class="tag {{item.type === 'service' ? 'tag-service' : 'tag-goods'}}">{{item.type === 'service' ? '服务' : '物品'}}</text>
            <text class="tag">{{item.category}}</text>
          </view>
          <text class="price">¥{{item.price}}</text>
        </view>
        <view class="card-title text-ellipsis-2">{{item.title}}</view>
        <view class="card-desc text-ellipsis-2">{{item.description}}</view>
        <view class="card-footer flex-between">
          <view class="flex-row">
            <image class="avatar-sm" src="{{item.seller.avatar}}"></image>
            <text class="seller-name">{{item.seller.name}}</text>
          </view>
          <text class="time">{{item.createTime}}</text>
        </view>
      </navigator>
    </block>
    <view wx:if="{{items.length === 0}}" class="empty">暂无内容</view>
  </view>

  <!-- 发布按钮 -->
  <view class="float-btn" bindtap="goPublish">
    <text class="float-icon">+</text>
  </view>
</view>