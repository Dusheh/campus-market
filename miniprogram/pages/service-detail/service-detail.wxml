<!-- 服务详情 -->
<view class="container">
  <view class="card">
    <image class="detail-image" src="{{service.image}}" mode="aspectFill"></image>
    <view class="flex-between" style="margin-top: 24rpx">
      <text class="tag tag-service">服务</text>
      <text class="price">¥{{service.price}}</text>
    </view>
    <view class="title">{{service.title}}</view>
    <view class="meta">
      <text><text class="label">分类</text> {{service.category}}</text>
      <text><text class="label">服务材出</text> {{service.location}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">服务详情</view>
    <view class="desc">{{service.description}}</view>
  </view>

  <view class="card">
    <view class="section-title">接单者</view>
    <view class="flex-row">
      <image class="avatar" src="{{service.seller.avatar}}"></image>
      <view>
        <text class="name">{{service.seller.name}}</text>
        <text class="time">{{service.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="btn-primary" bindtap="buyNow">随等资逜</button>
  </view>
</view>