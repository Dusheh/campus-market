.image-swiper {
  height: 500rpx;
  margin-bottom: 20rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 16rpx 0;
}

.meta {
  font-size: 24rpx;
  color: #999;
}

.divider-v {
  margin: 0 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.rate {
  display: block;
  font-size: 24rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.bar-icon {
  font-size: 40rpx;
  margin-right: 30rpx;
}