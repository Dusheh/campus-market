.chat-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: #ccc;
}

.last-msg {
  font-size: 26rpx;
  color: #999;
  max-width: 400rpx;
  margin-top: 8rpx;
}

.badge {
  background: #E53935;
  color: #ffffff;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 8rpx;
}

.empty {
  text-align: center;
  color: #ccc;
  padding: 100rpx 0;
}