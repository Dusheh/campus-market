.user-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #ffffff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.school {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.stats {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.menu-section {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}