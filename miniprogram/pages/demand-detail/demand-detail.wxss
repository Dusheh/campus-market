.urgent-card {
  background: #FFF3E0;
  text-align: center;
}

.urgent-tag {
  font-size: 32rpx;
  font-weight: 700;
  color: #E65100;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 16rpx 0;
}

.meta {
  font-size: 24rpx;
  color: #999;
}

.divider-v {
  margin: 0 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}