/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-outline {
  background-color: transparent;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-service {
  background-color: #E3F2FD;
  color: #1976D2;
}

.tag-goods {
  background-color: #FFF3E0;
  color: #F57C00;
}

.tag-demand {
  background-color: #FCE4EC;
  color: #C62828;
}

/* 文本省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 价格样式 */
.price {
  color: #E53935;
  font-weight: 600;
  font-size: 32rpx;
}

.price-unit {
  font-size: 24rpx;
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #eeeeee;
  margin: 20rpx 0;
}